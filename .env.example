# Copy this file to .env and fill in your keys
# Never commit .env to git

# Reddit API — get from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=CognitiveMotive/1.0 by your_reddit_username

# Kaggle — download kaggle.json from https://www.kaggle.com/settings
# and place it at C:\Users\surya\.kaggle\kaggle.json
# No env vars needed after that — kaggle CLI reads it automatically

# Weights & Biases — get from https://wandb.ai/settings (optional, for tracking)
WANDB_API_KEY=your_wandb_key_here

# HuggingFace — get from https://huggingface.co/settings/tokens (optional, for uploading model)
HF_TOKEN=your_hf_token_here
